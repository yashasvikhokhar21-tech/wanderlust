<div id="chat-widget" class="chat-widget">
  <button id="chat-open-btn" class="chat-open">💬</button>
  <div class="chat-panel">
    <div class="chat-header">WanderLust Assistant</div>
    <div id="chat-messages" class="chat-messages" aria-live="polite"></div>
    <form id="chat-form" class="chat-form">
      <input id="chat-input" class="form-control" placeholder="Ask about listings, e.g. 'Find listings in Goa'" autocomplete="off" />
      <button class="btn btn-accent btn-sm ms-2" type="submit">Send</button>
    </form>
  </div>
</div>
