<% layout("/layouts/boilerplate") %>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <br><br>
      <h2>Create a new listing</h2>
      <br>
      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Title:</label>
          <input type="text" name="listing[title]" placeholder="Add a catchy Title" class="form-control" required>
          <div class="valid-feedback">Title looks good!</div>
        </div>


        <div class="mb-3">
          <label for="description" class="form-label">Description:</label>
          <textarea name="listing[description]" placeholder="Enter Description" class="form-control"
            required></textarea>
          <div class="invalid-feedback">Please enter valid description!</div>
        </div>

        <div class="mb-3">
          <label for="imageUrl" class="form-label">Image Link</label>
          <input type="text" id="imageUrl" name="listing[image][url]" placeholder="https://example.com/photo.jpg" class="form-control">
          <div class="invalid-feedback">Please enter a valid URL or upload an image file!</div>
        </div>
        <div class="mb-3">
          <label for="imageFile" class="form-label">Or Upload Image</label>
          <input type="file" id="imageFile" name="image" class="form-control">
          <small class="form-text text-muted">The file input shows a fake path; only the image itself will be saved.</small>
        </div>

        <div class="row">
          <div class="mb-3 col-md-4 ">
            <label for="price" class="form-label">Price:</label>
            <input type="number" step="0.01" id="price" name="listing[price]" placeholder="1200" class="form-control"
              required>

            <div class="invalid-feedback">Please enter valid price !</div>
          </div>

          <div class="mb-3 col-8">
            <label for="country" class="form-label">Country:</label>
            <input type="text" id="country" name="listing[country]" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">Please enter valid country!</div>
          </div>
        </div>


        <div class="mb-3">
          <label for="location" class="form-label">Location:</label>
          <input type="text" name="listing[location]" placeholder="Jaipur, Rajasthan" class="form-control" required>
          <div class="invalid-feedback">Please enter valid location!</div>
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
