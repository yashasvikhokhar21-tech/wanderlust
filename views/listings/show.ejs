<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
    </div>
    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body">
          <p class="card-text">Posted By : <i> <%= listing.owner.username %></i><br>  </p>

           
           <p class="card-text"></p> <%= listing.description %><br></p>
                     <p class="card-text"></p> $ <%= listing.price %><br></p>
           <p class="card-text"></p> <%= listing.location %><br> </p>
           <p class="card-text"></p> <%= listing.country %></p>

                     <% if(currentUser && !currentUser._id.equals(listing.owner._id)) { %>
                         <hr>
                         <h5>Book this listing</h5>
                         <form action="/listings/<%= listing._id %>/bookings" method="POST" class="row g-2">
                             <div class="col-md-4">
                                 <label class="form-label">Start</label>
                                 <input type="date" name="booking[startDate]" class="form-control" required>
                             </div>
                             <div class="col-md-4">
                                 <label class="form-label">End</label>
                                 <input type="date" name="booking[endDate]" class="form-control" required>
                             </div>
                             <div class="col-md-2">
                                 <label class="form-label">Guests</label>
                                 <input type="number" name="booking[guests]" class="form-control" min="1" value="1">
                             </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button class="btn btn-accent btn-sm" type="submit">Request</button>
                            </div>
                         </form>
                     <% } %>

                                        <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
                                            <hr>
                                            <h5>Booking requests</h5>
                                            <% if(listing.bookings && listing.bookings.length){ %>
                                                <div class="list-group">
                                                    <% listing.bookings.forEach(function(b){ %>
                                                        <div class="list-group-item d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <strong>@<%= b.user.username %></strong>
                                                                <div><small><%= b.startDate.toDateString() %> → <%= b.endDate.toDateString() %></small></div>
                                                                <div><small>Guests: <%= b.guests %></small></div>
                                                                <div><small>Status: <%= b.status %></small></div>
                                                            </div>
                                                            <div>
                                                                <% if(b.status === 'pending'){ %>
                                                                    <form action="/listings/<%= listing._id %>/bookings/<%= b._id %>/accept" method="POST" class="d-inline">
                                                                        <button class="btn btn-accent btn-sm me-2">Accept</button>
                                                                    </form>
                                                                    <form action="/listings/<%= listing._id %>/bookings/<%= b._id %>/decline" method="POST" class="d-inline">
                                                                        <button class="btn btn-outline-dark btn-sm">Decline</button>
                                                                    </form>
                                                                <% } else { %>
                                                                    <span class="text-muted">No actions</span>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    <% }) %>
                                                </div>
                                            <% } else { %>
                                                <p class="text-muted">No booking requests yet.</p>
                                            <% } %>
                                        <% } %>

       
        </div>
    </div>
    <br>
   
</div>

<% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>
  <div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete </button>
    </form>
  </div>
<% } %>
  
<hr>

<div class="col-8 offset-3 mb-3">
  <% if(currentUser){ %>  
    <h4>Leave a review</h4>
    <form 
        action="/listings/<%= listing._id %>/review" 
        method="POST" 
        novalidate 
        class="needs-validation"
    >
    <div class="mb-3 mt-3">
                <!-- Star rating (submits as review[rating]) -->
                  <label for="rating" class="form-label" >Rating</label>
                <fieldset class="starability-slot" aria-label="Rating">
                    
                    <input 
                        type="radio" 
                        id="rating-no-rate" 
                        class="input-no-rate" 
                        name="review[rating]" 
                        value="1" 
                        checked 
                        aria-label="No rating" 
                    />
                    <input type="radio" id="rating-1" name="review[rating]" value="1" />
                    <label for="rating-1" title="Terrible">1 star</label>
                    <input type="radio" id="rating-2" name="review[rating]" value="2" />
                    <label for="rating-2" title="Not good">2 stars</label>
                    <input type="radio" id="rating-3" name="review[rating]" value="3" />
                    <label for="rating-3" title="Average">3 stars</label>
                    <input type="radio" id="rating-4" name="review[rating]" value="4" />
                    <label for="rating-4" title="Very good">4 stars</label>
                    <input type="radio" id="rating-5" name="review[rating]" value="5" />
                    <label for="rating-5" title="Amazing">5 stars</label>
                </fieldset>
        </div>

        <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" 
                id="[comment]" 
                col="30" 
                row="10" 
                class="form-control"
                required
            ></textarea>
            <div class="invalid-feedback">
                Please provide a comment.
            </div>



        </div>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr>
<% } %>    
    
    
    <p><b>All Reviews</b></p>
    <div class="row">
     <% for(review of listing.reviews){ %>
        <div class="card mb-3 col-5 ms-3">
            <div class="card-body">
                <h5 class="card-title">@<%= review.author.username %></h5>
                <p class="starability-result card-text" data-rating=<%= review.rating %>></p>
                <p class="card-text"><%= review.comment %></p>
                
                
            </div>

            <form action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE" class="mb-3" method="POST">
                <button class="btn btn-dark btn-sm">Delete</button>
            </form>
        </div>
        
     <% } %>   
     </div>
</div>
    
   
